PORT=3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alumni_platform
DB_USER=root
DB_PASS=your_mysql_password_here
DB_DIALECT=mysql

# JWT Authentication
# Used to sign and verify JSON Web Tokens for user sessions.
# Generate a strong random string (min 32 chars recommended).
JWT_SECRET=your_jwt_secret_key_here

# Email (Nodemailer) – used for verification codes and password reset emails
# For Gmail: enable "App Passwords" in Google Account settings
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Client URL – used in password reset email links
CLIENT_URL=http://localhost:5173

# Environment
NODE_ENV=development
